# .env.example - Copiar a .env y ajustar según tu ambiente
# NO incluir archivos .env en Git

# ============================================================
# BASE DE DATOS
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=la_esperanza
DB_USER=postgres
DB_PASSWORD=tu-password-seguro-aqui

# ============================================================
# JWT / SEGURIDAD
# ============================================================
JWT_SECRET=tu-clave-secreta-muy-larga-y-segura-minimo-32-caracteres
JWT_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://usuario.github.io

# ============================================================
# JAVA / SPRING
# ============================================================
JAVA_OPTS=-Xmx512m -Xms256m
SPRING_PROFILE_ACTIVE=dev

# ============================================================
# PGADMIN (opcional)
# ============================================================
PGADMIN_PASSWORD=admin

# ============================================================
# DOMINIO (para producción)
# ============================================================
API_DOMAIN=api.laesperanza.com
FRONTEND_DOMAIN=laesperanza.com
